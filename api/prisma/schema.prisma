generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Producto {
  id            Int      @id @default(autoincrement())
  nombre        String
  descripcion   String?
  precio        Decimal  @db.Decimal(10, 2)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("productos")
}
